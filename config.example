common: # Default settings
  mac: 00:??:??:??:??:?? # Make last 5 bytes random
  dns: 8.8.8.8, 8.8.4.4
  hostname: <name>s-MacBook-Pro # <name> is a table of generic names
  vpn: myvpn
  portal:
    check: auto   # "auto" (default) or "off"; anything else is rejected at load
    url: http://detectportal.firefox.com/success.txt
      # must be plain http with a host; a custom endpoint must answer
      # HTTP 204 or a 200 body of exactly "success" when internet works.
      # It should normally be an externally reachable public endpoint —
      # a LAN-local probe answers even when the internet is down.
      # (Self-hosted probes are allowed deliberately, for privacy.)
  timeouts:
    portal: 3     # captive-portal probe timeout in seconds

ignored:
  interfaces:
  - br[0-9]+
  - docker[0-9]+ # Docker
  - tap[0-9]+
  - tun[0-9]+
  - vboxnet[0-9]+ # Virtualbox
  - veth.*
  - vmnet[0-9]+ # VMWare
  - wg.* # Probably WireGuard
  - tailscale[0-9]+ # Tailscale
  - wt[0-9]+ # NetBird

vpn:
  myvpn:
    type: openvpn
    config: |
      client
      dev tun

      proto udp
      remote my-server-1 1194

      resolv-retry infinite
      nobind
      persist-key
      persist-tun

      ca ca.crt
      cert client.crt
      key client.key

      comp-lzo
      verb 3
  myvpn2:
    type: wireguard
    address: 10.0.0.2/32
    interface: wg0
    gateway: true
    config: |
      [Interface]
      PrivateKey = YOUR_PRIVATE_KEY_HERE

      [Peer]
      Endpoint = vpn.example.com:51820
      PublicKey = SERVER_PUBLIC_KEY_HERE
      AllowedIPs = 0.0.0.0/0
  my-tailscale:
    type: tailscale
    profile: work@company.com      # Optional: switch Tailscale profile (multi-account)
    auth_key: tskey-auth-xxxxx     # Optional: omit if already logged in via browser
    exit_node: us-east-1           # Optional: route traffic through exit node
    accept_routes: true            # Optional: accept subnet routes from admin
  personal-tailscale:
    type: tailscale
    profile: me@gmail.com          # Switch to personal account
  my-netbird:
    type: netbird
    profile: work                  # Optional: NetBird profile (multi-account)
    auth_key: tskey-auth-xxxxx     # Optional: omit if already logged in via browser
    exit_node: us-east-1           # Optional: route traffic through exit node
    accept_routes: true            # Optional: accept subnet routes from admin
  my-netbird:
    type: netbird
    setup_key: XXXXXXXX            # Optional: omit if already logged in
    management_url: https://api.netbird.io  # Optional: defaults to NetBird cloud

office:
  vpn: myvpn
  routes:
    - 192.168.0.0/16 -> 192.168.1.1 # Local network

crappy-hotel-wifi:
  ssid: FreeWiFi
  # Pin access point address to avoid switching between a gazillion equally
  # crappy ones.  This tends to give a more reliable connection.
  ap-addr: 00:11:22:33:44:55
  vpn: my-tailscale # Connect via Tailscale exit node when away from home

wired:
  dns: dhcp
  mac: default # The default is to pick a random Macbook Pro MAC address
  hostname: # Do not send a hostname

# Alias chooses different configuration for each host
static: static-$(hostname)

static-laptop:
  interface: eth0
  addr: 192.168.0.42/24
  gateway: 192.168.0.1
  routes:
    - default

static-desktop:
  interface: eth0
  addr: 192.168.0.43/24
  gateway: 192.168.0.1
  routes:
    - default

eduroam:
  ssid: eduroam
  wpa: |
    network={
      identity="YOUR-ID-HERE"
      password="YOUR-PASSPHRASE-HERE"
      key_mgmt=WPA-EAP
    }

my-home-network:
  ssid: SSID-HERE
  psk: PASSPHRASE-HERE
  vpn: # Do not connect to VPN when at home
